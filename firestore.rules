/**
 * FIRESTORE SECURITY RULES
 * 
 * Core Philosophy:
 * This ruleset implements a Role-Based Access Control (RBAC) model optimized for a professional 
 * portfolio. It distinguishes between the "Founder/Admin" who manages content and the "Public" 
 * who consumes it. Security is anchored in a dedicated /roles_admin/ collection where the 
 * existence of a document grants global write privileges.
 * 
 * Data Structure:
 * - /globalContent/: Single-document configuration for site-wide settings.
 * - /expertises/, /categories/, /projects/, /socialLinks/: Flat collections for portfolio data.
 * - /roles_admin/{uid}: A registry of authorized admin UIDs.
 * 
 * Key Security Decisions:
 * - Public Read Access: All portfolio content is publicly readable (get/list) to ensure SEO 
 *   friendliness and zero-friction access for visitors.
 * - Admin-Only Writes: Write operations (create, update, delete) are strictly restricted to 
 *   authenticated users whose UID is present in the /roles_admin/ collection.
 * - Authorization Independence: Rules avoid costly recursive lookups by using a flat 
 *   administrative check. This ensures high performance and atomic write capabilities.
 * - Prototyping Flexibility: While authorization is strictly enforced based on roles, 
 *   data shapes (schemas) are kept flexible to allow for rapid iterative development.
 * 
 * Denormalization for Authorization:
 * Instead of checking fields inside every content document, we use a dedicated "Roles" 
 * collection (/roles_admin/). This pattern allows the security rules to verify administrative 
 * identity with a single `exists()` check, regardless of the content being modified.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Verifies if the authenticated user has administrative privileges 
     * by checking for their UID in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Ensures the document exists before allowing modifications or deletions.
     */
    function isExisting() {
      return resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Stores global configuration and site-wide content.
     * @path /globalContent/{globalContentId}
     * @allow Public (get, list); Admins (create, update, delete)
     * @deny Non-admin users (write)
     * @principle Role-Based Access Control (RBAC).
     */
    match /globalContent/{globalContentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExisting();
    }

    /**
     * @description Individual expertise areas showcased in the portfolio.
     * @path /expertises/{expertiseId}
     * @allow Public (get, list); Admins (create, update, delete)
     * @deny Unauthenticated users (write)
     * @principle Role-Based Access Control (RBAC).
     */
    match /expertises/{expertiseId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExisting();
    }

    /**
     * @description Grouping categories for projects.
     * @path /categories/{categoryId}
     * @allow Public (get, list); Admins (create, update, delete)
     * @deny Non-admin users (write)
     * @principle Role-Based Access Control (RBAC).
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExisting();
    }

    /**
     * @description Detailed project information.
     * @path /projects/{projectId}
     * @allow Public (get, list); Admins (create, update, delete)
     * @deny Guest users (write)
     * @principle Role-Based Access Control (RBAC).
     */
    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExisting();
    }

    /**
     * @description Links to external social media profiles.
     * @path /socialLinks/{socialLinkId}
     * @allow Public (get, list); Admins (create, update, delete)
     * @deny Non-admin users (write)
     * @principle Role-Based Access Control (RBAC).
     */
    match /socialLinks/{socialLinkId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExisting();
    }

    /**
     * @description Database-Backed Access Control (DBAC) for admin roles.
     * @path /roles_admin/{adminUid}
     * @allow Admin users (get their own role)
     * @deny Public (get, list, write); Admins (list, create, update, delete via client SDK)
     * @principle Authorization Independence and structural segregation.
     */
    match /roles_admin/{adminUid} {
      // Admins can verify their own role status.
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      // Writing to roles is restricted to system processes or manual DB intervention for security.
      allow list, create, update, delete: if false;
    }
  }
}